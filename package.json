{
  "name": "bharatnaukri-live",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "description": "BharatNaukri — frontend (Vite) and official-site fetch scripts",
  "devDependencies": {
    "cheerio": "^1.1.2",
    "rss-parser": "^3.13.0"
  },
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "api:dev": "node scripts/run-api-dev.mjs",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "type-check": "npm run type-check --prefix frontend",
    "fetch:official": "node --experimental-strip-types scripts/fetch-all-official.mjs",
    "fetch:historical": "node scripts/fetch-historical-notifications.mjs",
    "registry:generate": "node scripts/generate-scraper-registry.mjs",
    "ingest:all": "node scripts/run-ingest-all.mjs",
    "ingest:direct": "node scripts/run-python.mjs scripts/run-ingest-direct.py",
    "ingest:direct:quick": "node scripts/run-python.mjs scripts/run-ingest-direct.py --limit 20",
    "data:refresh": "node scripts/run-python.mjs scripts/run-full-data-refresh.py",
    "data:scrub": "node scripts/run-python.mjs scripts/scrub-aggregator-from-db.py",
    "clean:live-jobs": "node scripts/run-python.mjs scripts/clean-live-jobs-json.py",
    "backfill:pdfs": "node scripts/run-python.mjs scripts/backfill-job-pdfs.py",
    "enrich:jobs": "node scripts/run-python.mjs scripts/enrich-jobs-metadata.py",
    "fetch:official:sites": "node scripts/fetch-official-sites.mjs",
    "audit:official-sites": "node scripts/audit-official-sites.mjs",
    "i18n:generate": "npm run i18n:generate --prefix frontend",
    "i18n:fill": "npm run i18n:fill --prefix frontend",
    "verify": "node scripts/verify-stack.mjs",
    "check:frontend": "node scripts/check-frontend-hygiene.mjs",
    "vercel:link": "vercel link",
    "vercel:env:push": "node scripts/push-vercel-env.mjs",
    "vercel:deploy": "vercel --prod",
    "supabase:test": "node scripts/test-supabase-connection.mjs",
    "supabase:audit": "node scripts/audit-supabase-tables.mjs",
    "supabase:sync-sources": "node scripts/run-python.mjs scripts/run-supabase-sync-sources.py",
    "supabase:full-sync": "node scripts/run-python.mjs scripts/run-supabase-full-sync.py",
    "supabase:import-official": "node scripts/run-python.mjs scripts/import-official-json-to-db.py",
    "db:test": "node scripts/run-python.mjs scripts/test-backend-db.py"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0"
  }
}
