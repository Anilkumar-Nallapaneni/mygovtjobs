# Copy to backend/.env — use placeholders only in this file
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SQL_ECHO=0
ADMIN_API_KEY=change-me-in-production
ALLOW_INSECURE_ADMIN=0
APP_ENV=development
ALLOW_FALLBACK_JSON_EXPORT=1
CORS_ORIGINS=http://localhost:2222,http://localhost:2223,http://127.0.0.1:2222,http://127.0.0.1:2223
RATE_LIMIT_PER_MINUTE=120
INGEST_LOOKBACK_DAYS=60
INGEST_MAX_ITEMS_PER_SOURCE=120
# Daily IngestAgent — 8:00 AM IST, one sync per calendar day
DAILY_SYNC_HOUR_IST=8
DAILY_SYNC_MINUTE_IST=0
DAILY_SYNC_ENFORCE_ONCE=1
