# Public keys only — never put service_role here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Local dev: empty (Vite proxies /api → :8000). Vercel: leave empty unless API is hosted elsewhere.
VITE_API_URL=
# Local: api (with npm run api:dev). Vercel production: supabase. Use auto for Supabase -> API -> static fallback.
VITE_JOBS_SOURCE=supabase
# Cache snapshot until next 8 AM IST run (no intraday JSON refresh)
VITE_DAILY_SYNC_ONLY=1
